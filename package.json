    "ts-loader": "^9.4.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  },
  "keywords": [
    "vibe-kibana",
    "elasticsearch",
    "react",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22"
  }
}
