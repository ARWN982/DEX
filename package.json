{
  "name": "vibe-kibana",
  "version": "1.0.0",
  "description": "A design system and prototyping environment for Kibana experiences.",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "npm run copy:chart-themes && tsc && webpack && node scripts/generate-versions-manifest.js",
    "build:server": "tsc  && tsc-alias",
    "build:client": "webpack",
    "copy:chart-themes": "mkdir -p public/css && cp node_modules/@elastic/charts/dist/theme_only_light.css public/css/ && cp node_modules/@elastic/charts/dist/theme_only_dark.css public/css/",
    "start": "node dist/server/index.js",
    "start:server": "nodemon --watch src/server --ext ts --exec \"npm run build:server && npm start\"",
    "start:client": "webpack serve --mode development",
    "dev": "npm run copy:chart-themes && concurrently \"npm run start:server\" \"npm run start:client\"",
    "test": "echo \"No tests specified\" && exit 0",
    "lint": "eslint src/ --ext .ts,.tsx --fix",
    "lint:check": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "perf:fields": "node scripts/perf-test-fields-api.js",
    "perf:setup": "node scripts/setup-performance-index.js",
    "perf:benchmark": "node scripts/perf-benchmark-suite.js"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-sql": "^6.9.1",
    "@codemirror/language": "^6.11.3",
    "@codemirror/lint": "^6.8.5",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.1",
    "@elastic/charts": "^71.1.2",
    "@elastic/datemath": "^5.0.3",
    "@elastic/elasticsearch": "^9.0.3",
    "@elastic/eui": "^112.2.0",
    "@elastic/eui-theme-borealis": "^5.3.0",
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@formatjs/intl": "^3.1.6",
    "@monaco-editor/react": "^4.7.0",
    "@playwright/test": "^1.55.0",
    "@tanstack/react-query": "^5.81.2",
    "chart.js": "^4.5.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.1",
    "express": "^4.18.0",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0",
    "leva": "^0.10.1",
    "moment": "^2.29.0",
    "moment-timezone": "^0.5.32",
    "monaco-editor": "^0.52.2",
    "numeral": "^2.0.6",
    "phosphor-react": "^1.4.1",
    "playwright": "^1.55.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.2.0",
    "react-grid-layout": "^2.2.2",
    "react-router-dom": "^6.26.2",
    "reselect": "^5.1.1",
    "serialize-query-params": "^2.0.2",
    "tsconfig-paths": "^4.2.0",
    "tsd": "^0.32.0",
    "use-query-params": "^2.2.1",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/glob": "^8.1.0",
    "@types/js-yaml": "^4.0.5",
    "@types/moment": "^2.13.0",
    "@types/node": "^20.0.0",
    "@types/numeral": "^2.0.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "ajv": "^8.17.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.0",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^6.8.0",
    "eslint": "^9.30.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "html-webpack-plugin": "^5.5.0",
    "monaco-editor-webpack-plugin": "^7.1.0",
    "nodemon": "^3.0.0",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.1.1",
